@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <Authorizing/>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <PageTitle>Not Found</PageTitle>
                <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center mt-16 pt-8">
                    <MudIcon Icon="@Icons.Material.Filled.FindInPage" Style="font-size: 6rem;" Color="Color.Secondary" Class="mb-4" />
                    <MudText Typo="Typo.h3" Class="mb-4 text-center">404</MudText>
                    <MudText Typo="Typo.h6" Class="mb-8 text-center" Style="opacity: 0.8">Sorry, we couldn't find the page you were looking for.</MudText>
                    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Home" Size="Size.Large">
                        Return Home
                    </MudButton>
                </MudContainer>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>