@using ApexCharts
@using Diabits.Web.Models
@inject DashboardService DashboardService
@inject ISnackbar Snackbar

<MudPaper Elevation="2" Class="pa-2 d-flex flex-grow-1">

    @if (_timeline != null && HasData())
    {
        @* TODO Show weekday in date *@
        <MudContainer MaxWidth="MudBlazor.MaxWidth.False" Gutters="false" Class="pa-2">
            <ApexChart TItem="TimelinePoint"
                       @key="@($"timeline-{SelectedDate:yyyyMMdd}")"
                       Options="_chartOptions">

                <ApexPointTooltip>
                    @{
                        var hovered = context.DataPoint.Items.FirstOrDefault() as TimelinePoint;
                        if (hovered is null) return;
                    }
                    <TimelineTooltip Series ="_orderedSeries" GetPoint="GetPoint" Time="hovered.Time" />
                </ApexPointTooltip>

                <ChildContent>
                    @foreach (var s in _orderedSeries)
                    {
                        <ApexPointSeries TItem="TimelinePoint"
                                         Items="s.Points"
                                         Name="@s.Name"
                                         SeriesType="@MapSeriesType(s.Type)"
                                         XValue="p => p.Time"
                                         YValue="p => (decimal?)p.Value" />
                    }
                </ChildContent>
            </ApexChart>
        </MudContainer>
    }
    else if (_timeline != null)
    {
        @* TODO Make no data screen better *@
        <div class="d-flex justify-center align-items-center pa-8">
            <MudText Typo="Typo.body1" Color="MudBlazor.Color.Error">No data available for this date</MudText>
        </div>
    }
</MudPaper>

@code {
    [Parameter]
    public DateTime? SelectedDate { get; set; }

    [Parameter]
    public bool IsActiveTab { get; set; }

    private TimelineChartResponse? _timeline;
    private Dictionary<DateTime, Dictionary<string, TimelinePoint>> _pointsByTime = new();
    private List<TimelineSeries> _orderedSeries = [];
    private DateTime? _lastLoadedDate;
    private static readonly string[] _seriesOrder = { "Menstruation", "Sleep", "Workout", "Heart Rate", "Medication", "Insulin Bolus", "Glucose Level" };

    protected override async Task OnParametersSetAsync()
    {
        if (IsActiveTab && SelectedDate.HasValue && SelectedDate != _lastLoadedDate)
        {
            _lastLoadedDate = SelectedDate;
            await LoadTimelineDataAsync();
        }
    }

    private async Task LoadTimelineDataAsync()
    {
        if (!SelectedDate.HasValue) return;

        _timeline = null;
        StateHasChanged();

        try
        {
            _timeline = await DashboardService.GetTimelineAsync(SelectedDate.Value.Date);

            _orderedSeries = _timeline.Series
                .OrderBy(s =>
                    {
                        var i = Array.IndexOf(_seriesOrder, s.Name);
                        return i == -1 ? int.MaxValue : i;
                    })
                .ToList();

            BuildTimelineLookup();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load timeline data: {ex.Message}", Severity.Error);
        }
    }

    private void BuildTimelineLookup()
    {
        _pointsByTime = _timeline!.Series
            .SelectMany(s => s.Points.Select(p => new { s.Name, Point = p }))
            .GroupBy(x => x.Point.Time)
            .ToDictionary(
                g => g.Key,
                g => g.ToDictionary(x => x.Name, x => x.Point)
            );
    }

    private bool HasData()
        => _timeline?.Series.SelectMany(s => s.Points).Any(p => (p.Value ?? 0) != 0) == true;

    private static SeriesType MapSeriesType(TimelineSeriesType t) => t switch
    {
        TimelineSeriesType.Line => SeriesType.Line,
        TimelineSeriesType.Area => SeriesType.Area,
        TimelineSeriesType.Scatter => SeriesType.Scatter,
        TimelineSeriesType.Bar => SeriesType.Bar,
        _ => SeriesType.Line
    };
    
    //TODO Rethink this - passing too much or too little to the tooltip, maybe just pass the point and series and let it figure out what to show?
    private TimelinePoint? GetPoint(DateTime t, string seriesName)
        => _pointsByTime.TryGetValue(t, out var m) && m.TryGetValue(seriesName, out var p) ? p : null;
}